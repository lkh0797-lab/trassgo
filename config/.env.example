# 공공데이터포털(data.go.kr) API 인증키
# data.go.kr → 마이페이지 → 개발계정 → 일반 인증키(Decoding) 복사해서 붙여넣기
# 시군구별 품목별 / 품목별 국가별 두 API 모두 같은 키 사용
DATA_GO_KR_API_KEY=여기에_본인_decoding키_붙여넣기

# DART OpenAPI 키 (나중에 사용)
# https://opendart.fss.or.kr/ 가입 후 인증키 신청
DART_API_KEY=

# 텔레그램 봇 토큰 (나중에 사용)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
